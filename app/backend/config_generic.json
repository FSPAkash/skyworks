  "chatbot": {
    "intro": "Hi, I'm the Data BPC Co-Pilot. I run intake per I-CUP section. Open the section you're working on and I'll ask only the questions that section needs.",
    "outro": "Section intake captured. Move to the next I-CUP layer and I'll ask its questions.",
    "sections": {
      "infrastructure": {
        "intro": "Infrastructure: let's confirm the foundation and which source systems we connect to. I'll gather the connection and access details so Data - BPC can auto-pull from the right sources.",
        "questions": [
          { "id": "infraPosture", "prompt": "What is the Infrastructure posture?", "field": "Posture", "options": ["Provided (client owns it)", "Advise (we design it)", "Build (we stand it up)"] },
          { "id": "infraPlatform", "prompt": "What target platform does the work run on?", "field": "Target platform", "options": ["Microsoft Fabric", "Databricks", "Snowflake", "On-prem SQL Server", "Other"] },
          { "id": "infraSources", "prompt": "Which source systems are in scope? (from ERP, CRM, Databases, Email, External Sources)", "field": "Source systems", "options": ["ERP + CRM + Databases", "ERP + Databases only", "All: ERP + CRM + Databases + Email + External", "Databases only"] },
          { "id": "infraErp", "prompt": "Which ERP system do we connect to?", "field": "ERP system", "options": ["SAP", "ECC", "S/4 HANA", "PeopleSoft", "None"] },
          { "id": "infraDb", "prompt": "Which database platform holds the data?", "field": "Database", "options": ["SQL", "Oracle", "Db2", "Mixed"] },
          { "id": "infraExternal", "prompt": "Any external sources to include?", "field": "External sources", "options": ["Domain Specific Information", "Third-party APIs", "Flat files / EDI", "None"] },
          { "id": "infraConnType", "prompt": "How should Data - BPC connect to pull data?", "field": "Connection method", "options": ["Direct connection string", "Service account + API", "Read replica", "Metadata export only"] },
          { "id": "infraCreds", "prompt": "How are login / access credentials provided for auto-pull?", "field": "Credentials", "options": ["Service account (read-only)", "Named user credentials", "Key vault / secrets manager", "Provided per-source later"] },
          { "id": "infraAccessOwner", "prompt": "Who grants and owns access to these systems?", "field": "Access owner", "options": ["Client DBA team", "Client platform team", "System owners per source", "External vendor"] },
          { "id": "infraSecurity", "prompt": "What security controls apply to the connection?", "field": "Security", "options": ["MFA + IP allowlist", "VPN / private link", "Read-only role", "Standard credentials"] }
        ]
      },
      "collection": {
        "intro": "Collection: confirm how we pull raw inputs, and the access to each source so the pull is automated.",
        "questions": [
          { "id": "colMode", "prompt": "Is Collection manual, agentic, or hybrid?", "field": "Execution mode", "options": ["Agentic (automated ingestion)", "Manual (interviews / hand gathering)", "Hybrid"] },
          { "id": "colAccess", "prompt": "What access level do the collection credentials have?", "field": "Access model", "options": ["Read-only", "Read-only replica", "Metadata export only"] },
          { "id": "colScope", "prompt": "What do we collect from the connected sources?", "field": "Collection scope", "options": ["Schemas + tables + columns", "Metadata + logs", "Full extract"] }
        ]
      },
      "unification": {
        "intro": "Unification: confirm how we relate the collected material, and access to any lineage / reference systems.",
        "questions": [
          { "id": "uniMode", "prompt": "Is Unification manual, agentic, or hybrid?", "field": "Execution mode", "options": ["Agentic (agents build lineage)", "Manual (analysts model by hand)", "Hybrid"] },
          { "id": "uniConnect", "prompt": "What needs to be connected?", "field": "Connect", "options": ["Lineage & dependencies", "Entity / identity resolution", "Common model / taxonomy"] },
          { "id": "uniAccess", "prompt": "Is a lineage / catalog system available to pull from?", "field": "Lineage access", "options": ["Yes, API + credentials", "Partial / manual export", "No lineage tooling"] }
        ]
      },
      "presentation": {
        "intro": "Presentation: how do we hand this over so the client can act and own it?",
        "questions": [
          { "id": "presArtifacts", "prompt": "What are the handover artifacts?", "field": "Artifacts", "options": ["Reports + executive summary", "Dashboards", "Playbooks / runbooks", "Training / enablement"] },
          { "id": "presMode", "prompt": "Is Presentation produced agentically, manually, or hybrid?", "field": "Execution mode", "options": ["Agentic", "Manual", "Hybrid"] },
          { "id": "presAudience", "prompt": "Who is the executive audience?", "field": "Executive audience", "options": ["CIO / CTO", "Data leadership", "Steering committee"] }
        ]
      }
    }
