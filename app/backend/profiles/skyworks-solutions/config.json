  "chatbot": {
    "intro": "Hi, I'm the Data BPC Co-Pilot. I run intake per I-CUP section. Open the section you're working on and I'll ask only the questions that section needs.",
    "outro": "Section intake captured. Move to the next I-CUP layer and I'll ask its questions.",
    "sections": {
      "infrastructure": {
        "intro": "Infrastructure: confirm the Skyworks-owned foundation and the source systems we connect to, with connection and access details so Data - BPC can auto-pull from the ODS and reference systems.",
        "questions": [
          {
            "id": "infraPosture",
            "prompt": "What is the Infrastructure posture?",
            "field": "Posture",
            "options": [
              "Provided (Skyworks owns it)",
              "Advise",
              "Build"
            ]
          },
          {
            "id": "infraPlatform",
            "prompt": "What is the target platform for the medallion architecture?",
            "field": "Target platform",
            "options": [
              "Microsoft Fabric",
              "Databricks",
              "Snowflake",
              "Synapse"
            ]
          },
          {
            "id": "infraSources",
            "prompt": "Which source systems are in scope? (ERP, CRM, Databases, Email, External)",
            "field": "Source systems",
            "options": [
              "ODS + ERP + reference systems",
              "ODS + databases only",
              "All connected sources"
            ]
          },
          {
            "id": "infraErp",
            "prompt": "Which ERP system feeds the ODS?",
            "field": "ERP system",
            "options": [
              "SAP",
              "ECC",
              "S/4 HANA",
              "PeopleSoft"
            ]
          },
          {
            "id": "infraDb",
            "prompt": "Which database platform holds the ODS?",
            "field": "Database",
            "options": [
              "SQL",
              "Oracle",
              "Db2",
              "Mixed"
            ]
          },
          {
            "id": "infraConnType",
            "prompt": "How should Data - BPC connect to pull data?",
            "field": "Connection method",
            "options": [
              "Direct connection string",
              "Service account + API",
              "Read replica",
              "Metadata export only"
            ]
          },
          {
            "id": "infraCreds",
            "prompt": "How are login / access credentials provided for auto-pull?",
            "field": "Credentials",
            "options": [
              "Service account (read-only)",
              "Named user credentials",
              "Key vault / secrets manager",
              "Provided per-source later"
            ]
          },
          {
            "id": "infraAccessOwner",
            "prompt": "Who grants and owns ODS + source access?",
            "field": "Access owner",
            "options": [
              "Skyworks DBA team",
              "Skyworks Data Platform team",
              "System owners per source",
              "External vendor"
            ]
          },
          {
            "id": "infraSecurity",
            "prompt": "What security controls apply to the connection?",
            "field": "Security",
            "options": [
              "MFA + IP allowlist",
              "VPN / private link",
              "Read-only role",
              "Standard credentials"
            ]
          },
          {
            "id": "infraLineage",
            "prompt": "Is an automated lineage system (API) available?",
            "field": "Lineage system",
            "options": [
              "Yes, API available",
              "Partial / manual",
              "No lineage tooling"
            ]
          }
        ]
      },
      "collection": {
        "intro": "Collection: confirm what we ingest from the ODS and the access that lets Data - BPC pull it automatically.",
        "questions": [
          {
            "id": "colMetadata",
            "prompt": "Can FS ingest ODS metadata (schemas, tables, columns)?",
            "field": "Metadata ingestion",
            "options": [
              "Full catalog access",
              "Subset / by request",
              "Manual export"
            ]
          },
          {
            "id": "colCreds",
            "prompt": "What access level do the collection credentials have?",
            "field": "Collection access",
            "options": [
              "Read-only service account",
              "Read-only replica",
              "Metadata export only"
            ]
          },
          {
            "id": "colSsis",
            "prompt": "Are the ~250 SSIS packages available for inventory?",
            "field": "SSIS packages",
            "options": [
              "Yes, all packages",
              "Partial set",
              "Not available"
            ]
          },
          {
            "id": "colLogs",
            "prompt": "Are query logs available for usage scoring?",
            "field": "Query logs",
            "options": [
              "Yes, full logs",
              "Sampled window",
              "Not available"
            ]
          }
        ]
      },
      "unification": {
        "intro": "Unification: confirm lineage, ownership, and access to the reference systems we pull from.",
        "questions": [
          {
            "id": "uniOwnership",
            "prompt": "Are dataset owners documented for lineage mapping?",
            "field": "Data ownership",
            "options": [
              "Documented",
              "Partially known",
              "To be discovered"
            ]
          },
          {
            "id": "uniRefSystems",
            "prompt": "Which reference systems should lineage cover?",
            "field": "Reference systems",
            "options": [
              "All nine systems",
              "Core systems only",
              "SAP + Warehouse only"
            ]
          },
          {
            "id": "uniAccess",
            "prompt": "Is a lineage / catalog system available to pull from?",
            "field": "Lineage access",
            "options": [
              "Yes, API + credentials",
              "Partial / manual export",
              "No lineage tooling"
            ]
          }
        ]
      },
      "presentation": {
        "intro": "Presentation: confirm handover and audience.",
        "questions": [
          {
            "id": "presPriority",
            "prompt": "What should the transition backlog weight most heavily?",
            "field": "Prioritization",
            "options": [
              "Usage frequency",
              "Cost impact",
              "Migration complexity"
            ]
          },
          {
            "id": "presAudience",
            "prompt": "Who is the executive audience for the summary report?",
            "field": "Executive audience",
            "options": [
              "CIO / CTO",
              "Data leadership",
              "Program steering committee"
            ]
          },
          {
            "id": "presHandover",
            "prompt": "Preferred handover format for knowledge transfer?",
            "field": "Handover format",
            "options": [
              "Live workshops",
              "Recorded walkthroughs",
              "Documentation only"
            ]
          }
        ]
      }
    }
  },
